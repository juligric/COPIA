---
import type { GoogleBook } from "../lib/types";
interface Props { book: GoogleBook; }
const { book } = Astro.props;
const info = book.volumeInfo;
const thumbnail = info.imageLinks?.thumbnail ?? info.imageLinks?.smallThumbnail;
const autores = info.authors?.join(", ") ?? "Autor desconocido";
const categorias = info.categories?.join(", ");
const descripcion = info.description
  ? info.description.slice(0, 150) + (info.description.length > 150 ? "..." : "")
  : "Sin descripción disponible.";
---

<article class="card">
  <div class="cover">
    {thumbnail
      ? <img src={thumbnail} alt={`Tapa de ${info.title}`} />
      : <div class="no-cover">📖</div>
    }
  </div>
  <div class="info">
    <h3>{info.title}</h3>
    <p class="autor">{autores}</p>
    {categorias && <span class="categoria">{categorias}</span>}
    <p class="descripcion">{descripcion}</p>
    <button class="fav-btn" data-id={book.id} data-titulo={info.title} data-autores={autores} data-thumbnail={thumbnail ?? ""}>
      ♡ Guardar en favoritos
    </button>
  </div>
</article>

<style>
  .card {
    display: flex;
    gap: 1rem;
    background: white;
    border-radius: 10px;
    padding: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  }
  .cover img { width: 80px; object-fit: cover; border-radius: 4px; }
  .no-cover {
    width: 80px; height: 110px;
    background: #eee; border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem;
  }
  .info { flex: 1; }
  h3 { font-size: 1rem; margin-bottom: 0.2rem; }
  .autor { font-size: 0.85rem; color: #666; margin-bottom: 0.4rem; }
  .categoria {
    display: inline-block;
    background: #e8f0fe; color: #1a73e8;
    font-size: 0.75rem; padding: 0.1rem 0.5rem;
    border-radius: 20px; margin-bottom: 0.5rem;
  }
  .descripcion { font-size: 0.85rem; color: #444; margin-bottom: 0.7rem; }
  .fav-btn {
    background: none; border: 1px solid #ccc;
    padding: 0.3rem 0.8rem; border-radius: 6px;
    cursor: pointer; font-size: 0.85rem;
  }
  .fav-btn:hover { background: #fff3f3; border-color: #e74c3c; color: #e74c3c; }
  .fav-btn.guardado { background: #fff3f3; border-color: #e74c3c; color: #e74c3c; }
</style>
