---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Buscar libros">
  <section>
    <h1>Buscar libros</h1>
    <form id="search-form">
      <input type="text" id="search-input" placeholder="Ej: Harry Potter, García Márquez..." required />
      <button type="submit">Buscar</button>
    </form>
    <div id="results"></div>
  </section>
</Layout>

<style>
  h1 { margin-bottom: 1.5rem; font-size: 1.6rem; }
  form { display: flex; gap: 0.5rem; margin-bottom: 2rem; }
  input {
    flex: 1; padding: 0.6rem 1rem;
    border: 1px solid #ccc; border-radius: 8px; font-size: 1rem;
  }
  button[type="submit"] {
    padding: 0.6rem 1.4rem; background: #1a1a2e;
    color: white; border: none; border-radius: 8px;
    cursor: pointer; font-size: 1rem;
  }
  button[type="submit"]:hover { background: #2d2d5e; }
  #results { display: flex; flex-direction: column; gap: 1rem; }
  .msg { color: #666; text-align: center; padding: 2rem; }
  .card {
    display: flex; gap: 1rem; background: white;
    border-radius: 10px; padding: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  }
  .cover img { width: 80px; border-radius: 4px; object-fit: cover; }
  .no-cover {
    width: 80px; height: 110px; background: #eee;
    border-radius: 4px; display: flex;
    align-items: center; justify-content: center; font-size: 2rem;
  }
  .info { flex: 1; }
  .info h3 { font-size: 1rem; margin-bottom: 0.2rem; }
  .autor { font-size: 0.85rem; color: #666; margin-bottom: 0.4rem; }
  .categoria {
    display: inline-block; background: #e8f0fe; color: #1a73e8;
    font-size: 0.75rem; padding: 0.1rem 0.5rem;
    border-radius: 20px; margin-bottom: 0.5rem;
  }
  .anio { font-size: 0.8rem; color: #999; margin-bottom: 0.5rem; }
  .fav-btn {
    background: none; border: 1px solid #ccc;
    padding: 0.3rem 0.8rem; border-radius: 6px;
    cursor: pointer; font-size: 0.85rem;
  }
  .fav-btn:hover, .fav-btn.guardado {
    background: #fff3f3; border-color: #e74c3c; color: #e74c3c;
  }
</style>

<script>
  import { getSession } from "../lib/auth";
  import { buscarLibros, getCoverUrl } from "../lib/books";
  import { agregarFavorito } from "../lib/db";

  const session = await getSession();
  if (!session) window.location.href = "/login";

  const form = document.getElementById("search-form")!;
  const results = document.getElementById("results")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const query = (document.getElementById("search-input") as HTMLInputElement).value;
    results.innerHTML = `<p class="msg">Buscando...</p>`;

    try {
      const libros = await buscarLibros(query);
      if (!libros.length) {
        results.innerHTML = `<p class="msg">No se encontraron resultados.</p>`;
        return;
      }

      results.innerHTML = libros.map(libro => {
        const autores = libro.author_name?.join(", ") ?? "Autor desconocido";
        const categoria = libro.subject?.[0] ?? "";
        const coverUrl = libro.cover_i ? getCoverUrl(libro.cover_i) : "";
        const bookId = libro.key.replace("/works/", "");

        return `
          <article class="card">
            <div class="cover">
              ${coverUrl
                ? `<img src="${coverUrl}" alt="Tapa" />`
                : `<div class="no-cover">📖</div>`}
            </div>
            <div class="info">
              <h3>${libro.title}</h3>
              <p class="autor">${autores}</p>
              ${categoria ? `<span class="categoria">${categoria}</span>` : ""}
              ${libro.first_publish_year ? `<p class="anio">Publicado: ${libro.first_publish_year}</p>` : ""}
              <button class="fav-btn"
                data-id="${bookId}"
                data-titulo="${libro.title.replace(/"/g, '&quot;')}"
                data-autores="${autores.replace(/"/g, '&quot;')}"
                data-thumbnail="${coverUrl}">
                ♡ Guardar en favoritos
              </button>
            </div>
          </article>`;
      }).join("");

      document.querySelectorAll(".fav-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (!session) return;
          const b = btn as HTMLElement;
          try {
            await agregarFavorito(session.user.id, {
              book_id: b.dataset.id!,
              titulo: b.dataset.titulo!,
              autores: b.dataset.autores ?? null,
              thumbnail: b.dataset.thumbnail ?? null,
            });
            b.textContent = "♥ Guardado";
            b.classList.add("guardado");
          } catch {
            b.textContent = "Ya está en favoritos";
          }
        });
      });
    } catch {
      results.innerHTML = `<p class="msg">Error al buscar libros.</p>`;
    }
  });
</script>
