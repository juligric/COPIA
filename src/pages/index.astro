---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Buscar libros">
  <section>
    <h1>Buscar libros</h1>
    <form id="search-form">
      <input type="text" id="search-input" placeholder="Ej: Harry Potter, García Márquez..." required />
      <button type="submit">Buscar</button>
    </form>
    <div id="results"></div>
  </section>
</Layout>

<style>
  h1 { margin-bottom: 1.5rem; font-size: 1.6rem; }
  form { display: flex; gap: 0.5rem; margin-bottom: 2rem; }
  input {
    flex: 1; padding: 0.6rem 1rem;
    border: 1px solid #ccc; border-radius: 8px; font-size: 1rem;
  }
  button[type="submit"] {
    padding: 0.6rem 1.4rem; background: #1a1a2e;
    color: white; border: none; border-radius: 8px;
    cursor: pointer; font-size: 1rem;
  }
  button[type="submit"]:hover { background: #2d2d5e; }
  #results { display: flex; flex-direction: column; gap: 1rem; }
  .msg { color: #666; text-align: center; padding: 2rem; }
</style>

<script>
  import { getSession } from "../lib/auth";
  import { buscarLibros } from "../lib/googleBooks";
  import { agregarFavorito } from "../lib/db";

  const session = await getSession();
  if (!session) window.location.href = "/login";

  const form = document.getElementById("search-form")!;
  const results = document.getElementById("results")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const query = (document.getElementById("search-input") as HTMLInputElement).value;
    results.innerHTML = `<p class="msg">Buscando...</p>`;

    try {
      const libros = await buscarLibros(query);
      if (!libros.length) {
        results.innerHTML = `<p class="msg">No se encontraron resultados.</p>`;
        return;
      }

      results.innerHTML = libros.map(libro => {
        const info = libro.volumeInfo;
        const thumbnail = info.imageLinks?.thumbnail ?? info.imageLinks?.smallThumbnail ?? "";
        const autores = info.authors?.join(", ") ?? "Autor desconocido";
        const categoria = info.categories?.[0] ?? "";
        const desc = info.description
          ? info.description.slice(0, 150) + "..."
          : "Sin descripción disponible.";

        return `
          <article class="card">
            <div class="cover">
              ${thumbnail
                ? `<img src="${thumbnail}" alt="Tapa" />`
                : `<div class="no-cover">📖</div>`}
            </div>
            <div class="info">
              <h3>${info.title}</h3>
              <p class="autor">${autores}</p>
              ${categoria ? `<span class="categoria">${categoria}</span>` : ""}
              <p class="descripcion">${desc}</p>
              <button class="fav-btn"
                data-id="${libro.id}"
                data-titulo="${info.title}"
                data-autores="${autores}"
                data-thumbnail="${thumbnail}">
                ♡ Guardar en favoritos
              </button>
            </div>
          </article>`;
      }).join("");

      document.querySelectorAll(".fav-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (!session) return;
          const b = btn as HTMLElement;
          try {
            await agregarFavorito(session.user.id, {
              book_id: b.dataset.id!,
              titulo: b.dataset.titulo!,
              autores: b.dataset.autores ?? null,
              thumbnail: b.dataset.thumbnail ?? null,
            });
            b.textContent = "♥ Guardado";
            b.classList.add("guardado");
          } catch {
            b.textContent = "Ya está en favoritos";
          }
        });
      });
    } catch (err) {
      results.innerHTML = `<p class="msg">Error al buscar libros.</p>`;
    }
  });
</script>
